# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Polygon.io (for live price lookups)
VITE_POLYGON_API_KEY=your-polygon-key

# Anthropic (used server-side via Edge Function — do NOT put in VITE_ prefix in prod)
# For local dev only — in production use a Supabase Edge Function
VITE_ANTHROPIC_API_KEY=your-anthropic-key
