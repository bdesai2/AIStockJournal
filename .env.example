# Stock Journal - Environment Variables Example
# Copy this file to .env.local and fill in your actual values.
# NEVER commit .env.local to version control.

# ─── Supabase Configuration ───────────────────────────────────────────────────
# Get these from https://app.supabase.com/project/[PROJECT_ID]/settings/api

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ─── Google OAuth ────────────────────────────────────────────────────────────
# Create OAuth app at https://console.cloud.google.com
# Callback URL: http://localhost:5173/auth/callback (dev) or https://yourdomain.com/auth/callback (prod)

VITE_GOOGLE_CLIENT_ID=your-google-client-id-here

# ─── Claude API (for trade analysis) ─────────────────────────────────────────
# Get API key from https://console.anthropic.com

VITE_ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ─── Market Data APIs ───────────────────────────────────────────────────────
# Yahoo Finance - No API key needed (free tier)
# Finnhub - Get free API key from https://finnhub.io

VITE_FINNHUB_API_KEY=your-finnhub-api-key-here

# ─── Development Settings ──────────────────────────────────────────────────
# Set to 'development' in dev, 'production' in build

VITE_APP_ENV=development

# ─── Analytics (Optional) ──────────────────────────────────────────────────
# Google Analytics 4 Measurement ID (optional, not sent without user consent)

VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ─── Security Notes ────────────────────────────────────────────────────────
#
# 🔒 IMPORTANT - Keep these secrets safe:
#
# 1. NEVER commit .env.local to git
# 2. NEVER share API keys in public repositories
# 3. NEVER log these values to console
# 4. NEVER send to error tracking services without redaction
# 5. Use .env.local (git-ignored) for development
# 6. Use secure secret management (GitHub Secrets, Vercel Secrets) for production
#
# 🌐 HTTPS Only:
#
# - All API requests use HTTPS
# - Supabase enforces SSL
# - Cookies include 'Secure' flag
# - HSTS header recommended (server config)
#
# 🚨 If a secret is compromised:
#
# 1. Immediately rotate the key via the service dashboard
# 2. Check API usage logs for suspicious activity
# 3. If database credentials leaked: contact Supabase support
# 4. If Anthropic key leaked: regenerate via dashboard
# 5. If Google OAuth secret leaked: regenerate OAuth client
# 6. Review audit logs in Stock Journal for suspicious access
